    <string name="jail_report_residual_foreground_service">This app declares a foreground service, which it can use to keep running with a visible notification.</string>
    <string name="jail_report_residual_accessibility">Accessibility access cannot be limited by profile boundaries — within its own profile, the app can still observe other apps\u2019 UI.</string>
    <string name="jail_report_residual_overlay">Overlays can imitate other app UIs and capture taps in the overlay area.</string>
